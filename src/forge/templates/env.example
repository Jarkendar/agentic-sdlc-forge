# Secrets for Forge runtime. Copy this file to `.env` (which is gitignored)
# and fill in the values you actually need.
#
# Only set keys for providers your config.toml references. An all-Ollama
# config needs NO keys at all — `forge run` will not ask.

# Anthropic API key. Required if any persona uses provider = "anthropic"
# in .forge/config.toml.
# Get one from https://console.anthropic.com/settings/keys.
ANTHROPIC_API_KEY=
